menu "Component"

menu "Logging"

choice OPENEMBER_LOG_BACKEND
    prompt "Log backend"
    default OPENEMBER_LOG_BACKEND_SPDLOG

config OPENEMBER_LOG_BACKEND_ZLOG
    bool "zlog"

config OPENEMBER_LOG_BACKEND_SPDLOG
    bool "spdlog"

config OPENEMBER_LOG_BACKEND_BUILTIN
    bool "builtin (stderr)"

endchoice

config OPENEMBER_LOG_FILE
    string "zlog.conf path"
    depends on OPENEMBER_LOG_BACKEND_ZLOG
    default "/etc/openember/zlog.conf" if OPENEMBER_LOG_BACKEND_ZLOG

choice OPENEMBER_SPDLOG_LEVEL_CHOICE
    prompt "spdlog: log level"
    depends on OPENEMBER_LOG_BACKEND_SPDLOG
    default OPENEMBER_SPDLOG_LEVEL_INFO

config OPENEMBER_SPDLOG_LEVEL_DEBUG
    bool "debug"

config OPENEMBER_SPDLOG_LEVEL_INFO
    bool "info"

config OPENEMBER_SPDLOG_LEVEL_WARN
    bool "warn"

config OPENEMBER_SPDLOG_LEVEL_ERROR
    bool "error"

endchoice

choice OPENEMBER_SPDLOG_FLUSH_LEVEL_CHOICE
    prompt "spdlog: flush on level"
    depends on OPENEMBER_LOG_BACKEND_SPDLOG
    default OPENEMBER_SPDLOG_FLUSH_INFO

config OPENEMBER_SPDLOG_FLUSH_INFO
    bool "info"

config OPENEMBER_SPDLOG_FLUSH_WARN
    bool "warn"

config OPENEMBER_SPDLOG_FLUSH_ERROR
    bool "error"

endchoice

config OPENEMBER_SPDLOG_PATTERN
    string "spdlog: pattern"
    depends on OPENEMBER_LOG_BACKEND_SPDLOG
    default "[%Y-%m-%d %H:%M:%S.%e] [%^%l%$] %v"

config OPENEMBER_SPDLOG_ENABLE_STDOUT
    bool "spdlog: enable stdout sink"
    depends on OPENEMBER_LOG_BACKEND_SPDLOG
    default y

config OPENEMBER_SPDLOG_ENABLE_FILE
    bool "spdlog: enable file sink (rotating)"
    depends on OPENEMBER_LOG_BACKEND_SPDLOG
    default y

config OPENEMBER_SPDLOG_FILE_DIR
    string "spdlog: file directory"
    depends on OPENEMBER_SPDLOG_ENABLE_FILE
    default "/var/log/openember"

config OPENEMBER_SPDLOG_ROTATE_MAX_MB
    int "spdlog: rotate max size (MiB)"
    depends on OPENEMBER_SPDLOG_ENABLE_FILE
    default 10
    range 1 1024

config OPENEMBER_SPDLOG_ROTATE_MAX_FILES
    int "spdlog: rotate max files"
    depends on OPENEMBER_SPDLOG_ENABLE_FILE
    default 5
    range 1 100

config OPENEMBER_SPDLOG_ENABLE_SYSLOG
    bool "spdlog: enable syslog sink (journald can collect)"
    depends on OPENEMBER_LOG_BACKEND_SPDLOG
    default n

config OPENEMBER_SPDLOG_ENABLE_TOPIC
    bool "spdlog: enable topic sink (/openember/log)"
    depends on OPENEMBER_LOG_BACKEND_SPDLOG
    default y
    help
      Publish log entries to pub/sub topic so other nodes (web_dashboard/loggerd) can subscribe.

config OPENEMBER_SPDLOG_TOPIC_NAME
    string "spdlog: topic name"
    depends on OPENEMBER_SPDLOG_ENABLE_TOPIC
    default "/openember/log"
    help
      Pub/sub topic name for log stream.

config OPENEMBER_SPDLOG_TOPIC_PUB_URL
    string "spdlog: topic transport (msg_bus bind / LCM provider)"
    depends on OPENEMBER_SPDLOG_ENABLE_TOPIC
    default "udpm://239.255.76.67:7667?ttl=1" if OPENEMBER_MSGBUS_BACKEND_LCM
    default "tcp://*:7561"
    help
      Passed to msg_bus / TransportBackend init (must match selected msgbus backend).
      LCM: udpm://... ; NNG: tcp://*:7561 (example).

config OPENEMBER_SPDLOG_TOPIC_SUB_URL
    string "spdlog: topic hint (documentation; subscriber uses same msgbus as process)"
    depends on OPENEMBER_SPDLOG_ENABLE_TOPIC
    default "udpm://239.255.76.67:7667?ttl=1" if OPENEMBER_MSGBUS_BACKEND_LCM
    default "tcp://127.0.0.1:7561"
    help
      Reserved for diagnostics; log subscribers use msg_bus on the node default transport.

choice OPENEMBER_SPDLOG_TOPIC_LEVEL_CHOICE
    prompt "spdlog: topic publish level threshold"
    depends on OPENEMBER_SPDLOG_ENABLE_TOPIC
    default OPENEMBER_SPDLOG_TOPIC_LEVEL_INFO

config OPENEMBER_SPDLOG_TOPIC_LEVEL_DEBUG
    bool "debug"

config OPENEMBER_SPDLOG_TOPIC_LEVEL_INFO
    bool "info"

config OPENEMBER_SPDLOG_TOPIC_LEVEL_WARN
    bool "warn"

config OPENEMBER_SPDLOG_TOPIC_LEVEL_ERROR
    bool "error"

endchoice

config OPENEMBER_SPDLOG_TOPIC_RATE_LIMIT
    int "spdlog: topic rate limit (lines/sec, 0=unlimited)"
    depends on OPENEMBER_SPDLOG_ENABLE_TOPIC
    default 0
    range 0 1000000
    help
      Rate limit for topic publishing to protect bus bandwidth. 0 means unlimited.

endmenu

menu "Serialization / Config"

choice OPENEMBER_JSON_LIBRARY_CHOICE
    prompt "JSON library"
    default OPENEMBER_JSON_LIBRARY_CJSON

config OPENEMBER_JSON_LIBRARY_CJSON
    bool "cJSON (C)"

config OPENEMBER_JSON_LIBRARY_NLOHMANN
    bool "nlohmann/json (C++)"

endchoice

config OPENEMBER_USE_YAMLCPP
    bool "Enable yaml-cpp dependency"
    default y

endmenu

menu "Networking Utility"

config OPENEMBER_USE_ASIO
    bool "Enable standalone Asio dependency"
    default y

endmenu

menu "Motion / trajectory"

config OPENEMBER_USE_RUCKIG
    bool "Enable ruckig (jerk-limited trajectory; C++20)"
    default n
    help
      Optional MIT library for online motion generation. When enabled, CMake fetches or uses
      OPENEMBER_RUCKIG_LOCAL_SOURCE; link targets with ruckig::ruckig.

endmenu

menu "Network"

config OPENEMBER_COMPONENT_NETWORK
    bool "Build component: Network (high-level socket wrapper)"
    default y
    depends on OPENEMBER_ENABLE_OSAL
    help
      Build Components/Network library (URI-based high-level socket wrapper) on top of OSAL sockets.

endmenu

menu "MQTT (Eclipse Paho C)"

config OPENEMBER_COMPONENT_MQTT
    bool "Build component: MQTT client (Paho MQTT C + openember_mqtt)"
    default y
    help
      Fetches/builds Eclipse paho.mqtt.c and links it into the framework. Application-level broker
      URI and credentials belong in Application → examples (mqtt_emqx_client), not here.

config OPENEMBER_MQTT_PAHO_TLS
    bool "Build Paho with OpenSSL (TLS / ssl://)"
    default y
    depends on OPENEMBER_COMPONENT_MQTT
    help
      When enabled, CMake requires OpenSSL development packages (e.g. libssl-dev) so Paho is built
      as paho-mqtt3cs and ssl:// URIs work. Disable only for plain tcp:// brokers without TLS.

config OPENEMBER_MQTT_PAHO_ASYNC
    bool "Link Paho MQTTAsync (async API) in addition to MQTTClient"
    default n
    depends on OPENEMBER_COMPONENT_MQTT
    help
      openember::mqtt::Client uses only the synchronous MQTTClient API. Leave disabled to link only
      paho-mqtt3c(s) and reduce binary size. Enable if you call MQTTAsync elsewhere or need both libs.

endmenu

endmenu

