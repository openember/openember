config OPENEMBER_MODULE_TEMPLATE
    bool "Build app: examples/hello_node"
    default y
    depends on OPENEMBER_ENABLE_EXAMPLES

config OPENEMBER_EXAMPLE_MSGBUS_TWO_NODES
    bool "Build example: msgbus_two_nodes (msg_bus publisher/subscriber)"
    default y
    depends on OPENEMBER_ENABLE_EXAMPLES
    help
      Uses the same msg_bus API as framework nodes (NNG or LCM per Kconfig).

config OPENEMBER_EXAMPLE_MSGBUS_NNG_FORWARDER
    bool "Build example: msgbus_nng_forwarder"
    default y
    depends on OPENEMBER_ENABLE_EXAMPLES
    help
      Requires internal msgbus backend NNG; CMake skips otherwise.

config OPENEMBER_EXAMPLE_NETWORK_SOCKETS
    bool "Build example: network_sockets (tcp/udp/unix)"
    default y
    depends on OPENEMBER_ENABLE_EXAMPLES
    help
      Build apps/examples/network_sockets demos for OSAL sockets and Components/Network wrapper.

config OPENEMBER_EXAMPLE_MQTT_EMQX
    bool "Build example: mqtt_emqx_client (Paho C client → EMQX / MQTT broker)"
    default n
    depends on OPENEMBER_ENABLE_EXAMPLES
    depends on OPENEMBER_COMPONENT_MQTT
    help
      Uses openember::mqtt::Client. Configure broker URI, credentials and TLS below.

if OPENEMBER_EXAMPLE_MQTT_EMQX

config OPENEMBER_MQTT_EMQX_HOST
    string "Broker hostname (FQDN, no scheme; e.g. wa366005.ala.cn-hangzhou.emqxsl.cn)"
    default "broker.emqx.io"

choice OPENEMBER_MQTT_EMQX_TRANSPORT
    prompt "Transport (EMQX Cloud: 8883 vs 8084)"
    default OPENEMBER_MQTT_EMQX_TRANSPORT_MQTT_TLS
    help
      MQTT over TLS uses ssl:// on port 8883 by default. WebSocket over TLS uses wss:// on port 8084
      and path /mqtt by default. Use optional full URI below to override.

config OPENEMBER_MQTT_EMQX_TRANSPORT_MQTT_TLS
    bool "MQTT over TLS / SSL (ssl://, default port 8883)"

config OPENEMBER_MQTT_EMQX_TRANSPORT_WSS
    bool "WebSocket over TLS / SSL (wss://, default port 8084)"

endchoice

config OPENEMBER_MQTT_EMQX_PORT
    int "Broker port"
    range 1 65535
    default 8883 if OPENEMBER_MQTT_EMQX_TRANSPORT_MQTT_TLS
    default 8084 if OPENEMBER_MQTT_EMQX_TRANSPORT_WSS

config OPENEMBER_MQTT_EMQX_WSS_PATH
    string "WebSocket path (leading slash; EMQX default /mqtt)"
    depends on OPENEMBER_MQTT_EMQX_TRANSPORT_WSS
    default "/mqtt"

config OPENEMBER_MQTT_EMQX_BROKER_URI
    string "Optional: full broker URI (overrides host/port/transport if non-empty)"
    default ""
    help
      Leave empty to build URI from hostname + port + transport (recommended).
      Set e.g. tcp://host:1883 or a custom wss:// URL for special cases.

config OPENEMBER_MQTT_EMQX_CLIENT_ID
    string "MQTT client id"
    default "openember-mqtt-example"

config OPENEMBER_MQTT_EMQX_USERNAME
    string "MQTT username (optional)"
    default "emqx"

config OPENEMBER_MQTT_EMQX_PASSWORD
    string "MQTT password (optional)"
    default "public"

config OPENEMBER_MQTT_EMQX_TOPIC
    string "Subscribe/publish topic"
    default "emqx/c-test"

config OPENEMBER_MQTT_EMQX_SSL_CAFILE
    string "TLS CA certificate file path"
    default ""
    help
      Download from EMQX console. PEM text is often stored as .crt or .pem — both work if content is PEM.
      The process must be able to read this path (e.g. chmod a+r or run as root). Empty: use system trust
      or disable verify below.

config OPENEMBER_MQTT_EMQX_SSL_VERIFY
    bool "Verify MQTT server TLS certificate"
    default y

endif
