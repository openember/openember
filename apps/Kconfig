menu "Application"

config OPENEMBER_ENABLE_EXAMPLES
    bool "Build examples"
    default y

menu "system"

config OPENEMBER_MODULE_LAUNCH_MANAGER
    bool "Build app: system/launch_manager"
    default y

config OPENEMBER_MODULE_ALOGD
    bool "Build app: system/log_service"
    default y

config OPENEMBER_MODULE_DEVICE_MANAGER
    bool "Build app: system/device_manager"
    default y

config OPENEMBER_MODULE_CONFIG_MANAGER
    bool "Build app: system/config_service"
    default y

config OPENEMBER_MODULE_MONITOR_ALARM
    bool "Build app: system/health_monitor"
    default y

endmenu

menu "services"

config OPENEMBER_MODULE_OTA
    bool "Build app: services/ota_update_service"
    default y

config OPENEMBER_MODULE_WEB_SERVER
    bool "Build app: services/web_dashboard"
    default y

config OPENEMBER_WEB_DASHBOARD_ROOT_DIR
    string "web_dashboard web root directory"
    default "apps/services/web_dashboard/web_root"
    help
      Default web root directory for web_dashboard.
      If a relative path is used, CMake will treat it as relative to the repository root.

endmenu

menu "tools"

comment "No standalone tool nodes are bundled in-tree yet."

endmenu

menu "references"

config OPENEMBER_MODULE_ACQUISITION
    bool "Build app: references/sensor_data_reference"
    default y

endmenu

menu "examples"

config OPENEMBER_MODULE_TEMPLATE
    bool "Build app: examples/hello_node"
    default y

config OPENEMBER_EXAMPLE_PUBSUB_TWO_NODES
    bool "Build example: pubsub_two_nodes (publisher/subscriber)"
    default y
    help
      Requires a pub/sub transport backend (ZMQ/NNG/LCM); CMake skips if not selected.

config OPENEMBER_EXAMPLE_MSGBUS_NNG_FORWARDER
    bool "Build example: msgbus_nng_forwarder"
    default y
    help
      Requires internal msgbus backend NNG; CMake skips otherwise.

config OPENEMBER_EXAMPLE_NETWORK_SOCKETS
    bool "Build example: network_sockets (tcp/udp/unix)"
    default y
    help
      Build apps/examples/network_sockets demos for OSAL sockets and Components/Network wrapper.

endmenu

endmenu
