config OPENEMBER_MODULE_OTA
    bool "Build app: services/ota_update_service"
    default y

config OPENEMBER_MODULE_WEB_SERVER
    bool "Build app: services/web_dashboard"
    default y

config OPENEMBER_WEB_DASHBOARD_ROOT_DIR
    string "web_dashboard web root directory"
    default "apps/services/web_dashboard/web_root"
    depends on OPENEMBER_MODULE_WEB_SERVER
    help
      Default web root directory for web_dashboard.
      If a relative path is used, CMake will treat it as relative to the repository root.

config OPENEMBER_WEB_DASHBOARD_PORT
    int "web_dashboard HTTP port"
    default 8000
    range 1 65535
    depends on OPENEMBER_MODULE_WEB_SERVER
    help
      HTTP listen port for web_dashboard. Server binds to 0.0.0.0:<port>.

config OPENEMBER_MODULE_LOGGER
    bool "Build app: services/logger"
    default y

config OPENEMBER_LOGGER_PORT
    int "logger HTTP port (local)"
    default 18081
    range 1 65535
    depends on OPENEMBER_MODULE_LOGGER
    help
      Local listen port for logger service, typically bound to 127.0.0.1.

config OPENEMBER_LOGGER_LOG_DIR
    string "logger source log directory"
    default "/var/log/openember"
    depends on OPENEMBER_MODULE_LOGGER
    help
      Directory where logger scans *.log files generated by process log sinks.
