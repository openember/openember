#!/usr/bin/env bash
set -euo pipefail

resolve_realpath() {
  local p="$1"
  if command -v realpath >/dev/null 2>&1; then
    realpath "$p"
  else
    readlink -f "$p"
  fi
}

find_project_root() {
  # 1) explicit override
  if [[ -n "${OPENEMBER_ROOT:-}" ]]; then
    echo "${OPENEMBER_ROOT}"
    return 0
  fi

  # 2) run from project root (works for symlinked ember in repo root or /usr/local/bin)
  if [[ -f "./CMakeLists.txt" && -f "./scripts/kconfig/menuconfig.sh" ]]; then
    pwd
    return 0
  fi

  # 3) derive from script real path
  local self_real script_dir candidate
  self_real="$(resolve_realpath "${BASH_SOURCE[0]}")"
  script_dir="$(cd "$(dirname "${self_real}")" && pwd)"
  candidate="$(cd "${script_dir}/.." && pwd)"
  if [[ -f "${candidate}/CMakeLists.txt" && -f "${candidate}/scripts/kconfig/menuconfig.sh" ]]; then
    echo "${candidate}"
    return 0
  fi

  echo "Cannot locate OpenEmber project root." >&2
  echo "Please run from project root, or set OPENEMBER_ROOT=/path/to/openember." >&2
  return 1
}

ROOT_DIR="$(find_project_root)"
BUILD_DIR="${OPENEMBER_BUILD_DIR:-build}"
JOBS="${OPENEMBER_JOBS:-$(nproc)}"

usage() {
  cat <<EOF
OpenEmber CLI

Usage:
  ember menuconfig [build_dir]
  ember genconfig [build_dir]
  ember configure [build_dir]
  ember build [build_dir]
  ember all [build_dir]
  ember clean [build_dir]
  ember completion bash
  ember help

Environment:
  OPENEMBER_BUILD_DIR   default build dir (default: build)
  OPENEMBER_JOBS        parallel jobs for build (default: nproc)
  OPENEMBER_KCONFIG_NONINTERACTIVE=1  generate default .config without TUI
EOF
}

resolve_build_dir() {
  local arg="${1:-}"
  if [[ -n "${arg}" ]]; then
    echo "${arg}"
  else
    echo "${BUILD_DIR}"
  fi
}

cmd="${1:-help}"
arg_build_dir="${2:-}"
bd="$(resolve_build_dir "${arg_build_dir}")"

case "${cmd}" in
  menuconfig)
    bash "${ROOT_DIR}/scripts/kconfig/menuconfig.sh" "${bd}"
    ;;
  genconfig)
    bash "${ROOT_DIR}/scripts/kconfig/genconfig.sh" "${bd}"
    ;;
  configure)
    cmake -S "${ROOT_DIR}" -B "${bd}"
    ;;
  build)
    # Auto bootstrap config pipeline if needed.
    if [[ ! -f "${bd}/.config" ]]; then
      echo "[ember] ${bd}/.config not found, generating default config..." >&2
      OPENEMBER_KCONFIG_NONINTERACTIVE=1 bash "${ROOT_DIR}/scripts/kconfig/menuconfig.sh" "${bd}"
    fi
    if [[ ! -f "${bd}/config.cmake" ]]; then
      echo "[ember] ${bd}/config.cmake not found, generating..." >&2
      bash "${ROOT_DIR}/scripts/kconfig/genconfig.sh" "${bd}"
    fi
    cmake -S "${ROOT_DIR}" -B "${bd}"
    cmake --build "${bd}" -j"${JOBS}"
    ;;
  all)
    bash "${ROOT_DIR}/scripts/kconfig/menuconfig.sh" "${bd}"
    bash "${ROOT_DIR}/scripts/kconfig/genconfig.sh" "${bd}"
    cmake -S "${ROOT_DIR}" -B "${bd}"
    cmake --build "${bd}" -j"${JOBS}"
    ;;
  clean)
    rm -rf "${bd}"
    ;;
  completion)
    shell_name="${2:-bash}"
    case "${shell_name}" in
      bash)
        cat "${ROOT_DIR}/scripts/completions/ember.bash"
        ;;
      *)
        echo "Unsupported shell for completion: ${shell_name}" >&2
        echo "Currently supported: bash" >&2
        exit 1
        ;;
    esac
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "Unknown command: ${cmd}" >&2
    usage
    exit 1
    ;;
esac

