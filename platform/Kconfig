menu "Platform"

menu "OSAL"

config OPENEMBER_ENABLE_OSAL
    bool "Build OSAL (Thread / Mutex / Timer ...)"
    default y
    help
      Platform OSAL for Linux: mutex, thread join, sleep, monotonic clock.
      Produces static library openember_osal.

endmenu

config OPENEMBER_ENABLE_HAL
    bool "Build HAL (UART / I2C / SPI / GPIO / CAN ...)"
    depends on OPENEMBER_ENABLE_OSAL
    default y
    help
      Platform HAL: POSIX file I/O and UART via termios.
      Produces static library openember_hal. Requires OSAL.

endmenu

