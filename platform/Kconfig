menu "Platform"

menu "OSAL"

config OPENEMBER_ENABLE_OSAL
    bool "Build OSAL (Thread / Mutex / Timer ...)"
    default y
    help
      Platform OSAL for Linux: mutex, thread join, sleep, monotonic clock.
      Produces static library openember_osal.

endmenu

config OPENEMBER_ENABLE_LPIO
    bool "Build LPIO (Linux Peripheral I/O, C++ RAII)"
    default y
    help
      Modern C++ peripheral I/O: GPIO, UART, I2C, SPI, CAN, PWM, 1-Wire, RS485.
      Produces static library openember_lpio. Independent of other platform layers.

config OPENEMBER_ENABLE_LPIO_EXAMPLES
    bool "Build LPIO examples (serial_echo, i2c_scan, can_logger)"
    depends on OPENEMBER_ENABLE_LPIO
    default n
    help
      Build small demo programs under platform/lpio/examples/.
      Requires OPENEMBER_ENABLE_LPIO.

endmenu
